//@version=5
indicator("Advanced AVPS Pro+", shorttitle="AVPS+", overlay=true, precision=2, max_lines_count=500, max_labels_count=500)

// ===== INPUTS =====
vpLookback = input.int(200, "Volume Profile Lookback", minval=20)
vpRowSize = input.float(0.5, "VP Row Size (%)", minval=0.1, maxval=1, step=0.1) * 0.01
showPOC = input.bool(true, "Show Point of Control?")
showVA = input.bool(false, "Show Value Area?") // Simplified version

// ===== CORE CALCULATIONS =====
// Volume Profile Calculations
var float pocPrice = na
var float vaHigh = na
var float vaLow = na

// Simplified Volume Profile Implementation without arrays
if barstate.islast
    // Find price levels
    minPriceLevel = ta.lowest(low, vpLookback)
    maxPriceLevel = ta.highest(high, vpLookback)
    priceRange = maxPriceLevel - minPriceLevel
    stepSize = priceRange * vpRowSize
    
    // Initialize variables for POC tracking
    var float maxVolume = 0
    var float pointOfControl = na
    
    // Calculate approximate volume at each price level
    currentPrice = minPriceLevel
    while currentPrice <= maxPriceLevel
        volumeAtPrice = 0.0
        for i = 0 to vpLookback - 1
            if low[i] <= currentPrice and high[i] >= currentPrice
                volumeAtPrice += volume[i]
        
        // Track POC
        if volumeAtPrice > maxVolume
            maxVolume := volumeAtPrice
            pointOfControl := currentPrice
        
        currentPrice += stepSize
    
    pocPrice := pointOfControl

// Momentum Indicators
macdLine = ta.ema(close, 12) - ta.ema(close, 26)
macdSignal = ta.ema(macdLine, 9)
macdBullish = macdLine > macdSignal and macdLine[1] <= macdSignal[1]

obv = ta.obv
obvMa = ta.ema(obv, 20)
obvBullish = obv > obvMa and ta.rising(obv, 2)

// ===== VISUALIZATION =====
// Volume Profile Drawing
if barstate.islast and showPOC and not na(pocPrice)
    line.new(bar_index - vpLookback, pocPrice, bar_index, pocPrice, color=color.purple, width=2, style=line.style_dashed)
    label.new(bar_index, pocPrice, "POC", color=color.purple, textcolor=color.white, style=label.style_label_center)

// ===== DASHBOARD =====
var table infoTable = table.new(position.top_right, 2, 6, border_width=1)
if barstate.islast
    table.cell(infoTable, 0, 0, "AVPS+ Dashboard", bgcolor=color.purple, text_color=color.white, width=2)
    table.cell(infoTable, 0, 1, "POC Price", bgcolor=color.gray)
    table.cell(infoTable, 1, 1, str.tostring(pocPrice, "#.##"), bgcolor=color.blue)
    table.cell(infoTable, 0, 2, "MACD Signal", bgcolor=color.gray)
    table.cell(infoTable, 1, 2, macdBullish ? "Bullish" : "Neutral", bgcolor=macdBullish ? color.green : color.gray)
    table.cell(infoTable, 0, 3, "OBV Trend", bgcolor=color.gray)
    table.cell(infoTable, 1, 3, obvBullish ? "Bullish" : "Neutral", bgcolor=obvBullish ? color.green : color.gray)
    table.cell(infoTable, 0, 4, "Price vs POC", bgcolor=color.gray)
    table.cell(infoTable, 1, 4, not na(pocPrice) ? (close > pocPrice ? "Above" : "Below") : "N/A", 
              bgcolor=not na(pocPrice) ? (close > pocPrice ? color.green : color.red) : color.gray)

// ===== ALERTS =====
alertcondition(macdBullish and obvBullish, "Bullish Confirmation", "Bullish MACD and OBV convergence detected")
